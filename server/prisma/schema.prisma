
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}

model User {
  id          Int    @id @default(autoincrement())
  email       String @unique
  password    String
  age         Int?
  phoneNumber String
  role     Role   @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum Role {
  USER
  ADMIN
}

model Food {
  id          Int    @id @default(autoincrement())
  foodName    String
  price       Float
  image       String
  ingredients String

  category   FoodCategory @relation(fields: [categoryId], references: [id])
  categoryId Int

  foodOrderItems FoodOrderItems[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model FoodCategory {
  id           Int      @id @default(autoincrement())
  categoryName String
  foods        Food[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}



model FoodOrder {
  id             Int              @id @default(autoincrement())
  totalPrice     Float
  status         String
  foodOrderItems FoodOrderItems[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}



model FoodOrderItems {
  id          Int       @id @default(autoincrement())
  quantity    Int
  food        Food      @relation(fields: [foodId], references: [id])
  foodId      Int
  order       FoodOrder @relation(fields: [foodOrderId], references: [id])
  foodOrderId Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
